rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - profile: map (optional)
    //   - goals: map (optional)
    //   - habits: map (optional)
    //   - generatedMenu: map (optional)
    //   - shoppingList: map (optional)
    //   - meals: list (optional)
    //   - weights: list (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser() {
      let allowedKeys = ['profile', 'goals', 'habits', 'generatedMenu', 'shoppingList', 'meals', 'weights', 'chatMessages', 'checkedItems'];
      let data = request.resource.data;
      
      let hasValidKeys = data.keys().hasOnly(allowedKeys);
      
      // Size limits to prevent 1MB attacks and resource exhaustion
      let validMeals = !('meals' in data) || (data.meals is list && data.meals.size() <= 2000);
      let validWeights = !('weights' in data) || (data.weights is list && data.weights.size() <= 2000);
      let validChat = !('chatMessages' in data) || (data.chatMessages is list && data.chatMessages.size() <= 1000);
      let validChecked = !('checkedItems' in data) || (data.checkedItems is map && data.checkedItems.size() <= 500);
      
      return hasValidKeys && validMeals && validWeights && validChat && validChecked;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
      allow delete: if isOwner(userId);
    }
  }
}
