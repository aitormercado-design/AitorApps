rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model — documento raíz /users/{userId}
    // ===============================================================
    //
    // Campos del documento raíz (todos opcionales, escritos con merge):
    //   - profile:       map   — UserProfile (datos personales y preferencias)
    //   - goals:         map   — { calories, protein, carbs, fat }
    //   - generatedMenu: map   — menú semanal generado por Gemini
    //   - shoppingList:  map   — lista de la compra generada por Gemini
    //   - chatMessages:  list  — historial del chat con el coach IA
    //   - checkedItems:  map   — estado de checks en lista de compra
    //   - workoutPlan:   string — rutina semanal en Markdown (Gemini)
    //
    // Subcolecciones (documentos independientes, no en el doc raíz):
    //   - /meals/{mealId}     — comidas registradas
    //   - /weights/{weightId} — registros de peso
    //   - /habits/{fecha}     — hábitos diarios (agua, sueño, ejercicio)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser() {
      let allowedKeys = ['profile', 'goals', 'generatedMenu', 'shoppingList', 'chatMessages', 'checkedItems', 'workoutPlan'];
      let data = request.resource.data;

      let hasValidKeys = data.keys().hasOnly(allowedKeys);

      // Size limits to prevent 1MB attacks and resource exhaustion
      let validChat    = !('chatMessages' in data) || (data.chatMessages is list && data.chatMessages.size() <= 1000);
      let validChecked = !('checkedItems' in data) || (data.checkedItems is map  && data.checkedItems.size() <= 1000);
      // workoutPlan: string Markdown generado por Gemini — puede ser extenso.
      // Límite provisional de 50 000 caracteres; revisar cuando se implemente paginación.
      let validWorkout = !('workoutPlan' in data) || (data.workoutPlan is string && data.workoutPlan.size() <= 50000);

      return hasValidKeys && validChat && validChecked && validWorkout;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
      allow delete: if isOwner(userId);

      match /meals/{mealId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /weights/{weightId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /habits/{habitId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
  }
}
